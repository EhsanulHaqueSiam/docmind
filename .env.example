# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Gemini Models
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# Embedding
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=docmind_documents

# Storage
STORAGE_MODE=local
DOCS_DIRECTORY=docs
GCS_BUCKET=

# App
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Auth (leave empty for open access)
API_KEY=
CORS_ORIGINS=*

# Retrieval
TOP_K=10
RERANK_TOP_K=5
RERANK_CONTEXT_CHARS=500

# Upload
MAX_UPLOAD_SIZE_MB=100

# Ingestion
EMBEDDING_BATCH_SIZE=250

# Watcher
WATCHER_DEBOUNCE_SECONDS=2.0
